{
  "name": "template-workspace-simple",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.7.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "format": "prettier --write --cache .",
    "lint": "prettier --check --cache .",
    "test": "vitest",
    "type-check": "tsc --build --pretty",
    "typescript:run": "node --experimental-transform-types --conditions quilt:source",
    "typescript:watch": "node --experimental-transform-types --watch --conditions quilt:source"
  },
  "devDependencies": {
    "@quilted/rollup": "^0.4.0",
    "@quilted/vite": "^0.3.0",
    "@quilted/typescript": "^0.4.0",
    "rollup": "^4.61.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": false,
    "singleQuote": true,
    "trailingComma": "all"
  }
}
